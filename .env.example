# ─────────────────────────────────────────────────────────────────────────────
# Price Optimization Engine — Environment Configuration
# Copy this file to .env and adjust values for your environment.
# ─────────────────────────────────────────────────────────────────────────────

# ── Service Ports ─────────────────────────────────────────────────────────────
API_PORT=8000
STREAMLIT_PORT=8501

# ── Model Paths ───────────────────────────────────────────────────────────────
MODEL_PATH=models/best_model.joblib
SCALER_PATH=models/scaler.joblib
METRICS_PATH=models/model_metrics.joblib

# ── Training Behaviour ────────────────────────────────────────────────────────
# Set to "false" in Docker/production to prevent auto-training on startup.
# Models must be pre-trained and volume-mounted when this is "false".
AUTO_TRAIN_IF_MISSING=true

# ── Data Paths ────────────────────────────────────────────────────────────────
RAW_DATA_PATH=data/raw/retail_sales.csv
PROCESSED_DATA_PATH=data/processed/cleaned_data.csv

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
